{% comment %} Product Popup Modal (hidden) {% endcomment %}
<div class="popup-overlay js-popup-{{ product.id }}" data-product-id="{{ product.id }}" style="display:none;">
  <div class="popup-content">
    <button class="popup-close js-close-popup" aria-label="Close">&times;</button>
    <h2 class="popup-title">{{ product.title }}</h2>
    <img class="popup-image" src="{{ product.featured_image | img_url: '800x800' }}" alt="{{ product.title }}" loading="lazy">
    <p class="popup-price">
      {% if product.compare_at_price > product.price %}
        <span class="price--sale">{{ product.price | money }}</span>
        <span class="price--compare">{{ product.compare_at_price | money }}</span>
      {% else %}
        <span class="price--regular">{{ product.price | money }}</span>
      {% endif %}
    </p>
    <div class="popup-description">
      {{ product.description | strip_html | truncatewords: 40 }}
    </div>
    {% if product.variants.size > 1 %}
      <div class="popup-variants">
        {% for variant in product.variants %}
          <label class="variant-option">
            <input type="radio" name="variant-{{ product.id }}" value="{{ variant.id }}" {% if forloop.first %}checked{% endif %}>
            {{ variant.title }} – {{ variant.price | money }}
          </label>
        {% endfor %}
      </div>
    {% endif %}
    <button class="popup-add-to-cart js-add-to-cart" data-product-id="{{ product.id }}">Add to Cart</button>
  </div>
</div>
