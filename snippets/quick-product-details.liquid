{% comment %}
  ─────────────────────────────────────────────────────────────────────────────
  quick-product-details.liquid
  ─────────────────────────────────────────────────────────────────────────────
  Structured into 4 distinct rows:
    Row 1: Product Header (Image, Title, Description Details, and Price)
    Row 2: Color (Segmented Control Box)
    Row 3: Size (Select Dropdown Box with Arrow Separator)
    Row 4: ADD TO CART Button (Solid Black Box with Right Arrow)
  ─────────────────────────────────────────────────────────────────────────────
{% endcomment %}

{% if product != blank %}
  <div
    class="quick-product-details js-quick-product-details"
    id="quick-product-details-{{ product.id }}"
    role="dialog"
    aria-modal="true"
    aria-labelledby="quick-product-title-{{ product.id }}"
    data-product-id="{{ product.id }}"
    aria-hidden="true"
    style="display: none;"
  >
    <div class="quick-product-details__backdrop js-close-quick-details"></div>

    <div class="quick-product-details__card">
      {% comment %} Close Modal Button {% endcomment %}
      <button
        type="button"
        class="quick-product-details__close js-close-quick-details"
        aria-label="Close details modal"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>

      {% comment %} Hidden Variant Lookup Data {% endcomment %}
      {% for variant in product.variants %}
        <input
          type="hidden"
          class="js-variant-lookup"
          data-variant-id="{{ variant.id }}"
          data-option1="{{ variant.option1 | downcase }}"
          data-option2="{{ variant.option2 | downcase }}"
          data-option3="{{ variant.option3 | downcase }}"
          data-price="{{ variant.price | money }}"
          data-available="{{ variant.available }}"
        >
      {% endfor %}

      {% comment %} ═══════════════════════════════════════════════════════════
           ROW 1: Image, Title, Description Details & Price
         ═══════════════════════════════════════════════════════════ {% endcomment %}
      <div class="qpd-row qpd-row--header">
        <div class="qpd-header__media">
          {% if product.featured_image != blank %}
            <img
              src="{{ product.featured_image | image_url: width: 500 }}"
              alt="{{ product.featured_image.alt | default: product.title | escape }}"
              class="qpd-header__image"
              loading="lazy"
            >
          {% else %}
            <div class="qpd-header__placeholder">
              {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
            </div>
          {% endif %}
        </div>

        <div class="qpd-header__info">
          {% if product.vendor != blank %}
            <span class="qpd-header__vendor">{{ product.vendor }}</span>
          {% endif %}

          <h2 class="qpd-header__title" id="quick-product-title-{{ product.id }}">
            {{ product.title }}
          </h2>

          <div class="qpd-header__price-row">
            <span class="qpd-header__price js-product-price">
              {{ product.selected_or_first_available_variant.price | default: product.price | money }}
            </span>
            {% if product.compare_at_price > product.price %}
              <span class="qpd-header__compare-price">
                {{ product.compare_at_price | money }}
              </span>
            {% endif %}
          </div>

          {% if product.description != blank %}
            <div class="qpd-header__details">
              {{ product.description | strip_html | truncatewords: 25 }}
            </div>
          {% endif %}
        </div>
      </div>

      {% comment %} ═══════════════════════════════════════════════════════════
           ROW 2: Color (Segmented Control Box)
         ═══════════════════════════════════════════════════════════ {% endcomment %}
      <div class="qpd-row qpd-row--option">
        <label class="qpd-row__label">Color</label>

        {% assign color_option = product.options_with_values | where: "name", "Color" | first %}
        {% if color_option == blank %}{% assign color_option = product.options_with_values | where: "name", "Colour" | first %}{% endif %}
        {% if color_option == blank and product.options_with_values.size > 0 %}{% assign color_option = product.options_with_values[0] %}{% endif %}

        <div class="qpd-color-segmented-box">
          {% if color_option != blank and color_option.values.size > 0 %}
            {% for val in color_option.values %}
              <label class="qpd-color-segment">
                <input
                  type="radio"
                  name="quick-color-{{ product.id }}"
                  value="{{ val | downcase }}"
                  {% if forloop.first %}checked{% endif %}
                  class="js-option-radio js-color-radio"
                >
                <span class="qpd-color-segment__label">{{ val }}</span>
              </label>
            {% endfor %}
          {% else %}
            {% assign default_colors = "White,Black" | split: "," %}
            {% for val in default_colors %}
              <label class="qpd-color-segment">
                <input
                  type="radio"
                  name="quick-color-{{ product.id }}"
                  value="{{ val | downcase }}"
                  {% if forloop.first %}checked{% endif %}
                  class="js-option-radio js-color-radio"
                >
                <span class="qpd-color-segment__label">{{ val }}</span>
              </label>
            {% endfor %}
          {% endif %}
        </div>
      </div>

      {% comment %} ═══════════════════════════════════════════════════════════
           ROW 3: Size (Select Dropdown Box)
         ═══════════════════════════════════════════════════════════ {% endcomment %}
      <div class="qpd-row qpd-row--option">
        <label class="qpd-row__label">Size</label>

        {% assign size_option = product.options_with_values | where: "name", "Size" | first %}
        {% if size_option == blank and product.options_with_values.size > 1 %}{% assign size_option = product.options_with_values[1] %}{% endif %}

        <div class="qpd-select-box-wrapper">
          <span class="qpd-select-display-text js-size-selected-text">
            {% if size_option != blank and size_option.values.size > 0 %}
              {{ size_option.values.first }}
            {% else %}
              Medium
            {% endif %}
          </span>
          <select
            class="qpd-size-select js-option-select js-size-select"
            name="quick-size-{{ product.id }}"
            aria-label="Choose your size"
          >
            {% if size_option != blank and size_option.values.size > 0 %}
              {% for val in size_option.values %}
                <option value="{{ val | downcase }}" {% if forloop.first %}selected{% endif %}>
                  {{ val }}
                </option>
              {% endfor %}
            {% else %}
              <option value="small">Small</option>
              <option value="medium" selected>Medium</option>
              <option value="large">Large</option>
              <option value="xlarge">X-Large</option>
            {% endif %}
          </select>
          <div class="qpd-select-arrow-box">
            <svg class="qpd-chevron-down" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
          </div>
        </div>
      </div>

      {% comment %} ═══════════════════════════════════════════════════════════
           ROW 4: ADD TO CART Button (Solid Black Box with Right Arrow)
         ═══════════════════════════════════════════════════════════ {% endcomment %}
      <div class="qpd-row qpd-row--actions">
        <button
          type="button"
          class="qpd-submit-btn js-add-to-cart-trigger"
          data-product-id="{{ product.id }}"
          data-default-variant-id="{{ product.variants.first.id }}"
        >
          <span class="btn-text">ADD TO CART</span>
          <svg class="qpd-cart-arrow" width="28" height="16" viewBox="0 0 28 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="0" y1="8" x2="24" y2="8"></line>
            <polyline points="17 1 24 8 17 15"></polyline>
          </svg>
        </button>
      </div>

    </div>
  </div>
{% endif %}
