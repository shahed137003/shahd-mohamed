{% comment %}
  header.liquid - Custom Site Header Section
  ──────────────────────────────────────────
  Layout (three-column flex row)
  ──────
  LEFT    Hamburger toggle (mobile) / Brand logo (desktop)
  CENTER  Brand logo (mobile) / Tagline text (desktop)
  RIGHT   CTA button (desktop only)

  Below the main bar: collapsible mobile menu drawer
  ──────────────────────────────────────────
  Assets loaded by this section
  ──────────────────────────────
  assets/site-header.css  - section-scoped styles
  assets/site-header.js   - hamburger toggle + ripple enhancements
{% endcomment %}

{{ 'site-header.css' | asset_url | stylesheet_tag }}

<div class="custom-header section-{{ section.id }}" data-section-id="{{ section.id }}" data-section-type="header">
  <div class="custom-header__container">

    {% comment %} LEFT: Hamburger (mobile) / Brand logo (desktop) {% endcomment %}
    <div class="custom-header__left">
      {% comment %} Mobile hamburger button {% endcomment %}
      <button
        class="custom-header__menu-toggle"
        aria-label="Menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
      </button>

      {% comment %} Desktop brand name {% endcomment %}
      <a href="/" class="custom-header__logo custom-header__logo--desktop">
        TISSO VISION
      </a>
    </div>

    {% comment %} CENTER: Brand name (mobile) / Tagline (desktop) {% endcomment %}
    <div class="custom-header__center">
      {% comment %} Mobile brand name {% endcomment %}
      <a href="/" class="custom-header__logo custom-header__logo--mobile">
        TISSO VISION
      </a>

      {% comment %} Desktop tagline {% endcomment %}
      <p class="custom-header__tagline">
        {{ section.settings.tagline | default: 'Find the ideal gift for your loved ones.' }}
      </p>
    </div>

    {% comment %} RIGHT: CTA button (desktop only) {% endcomment %}
    <div class="custom-header__right">
      <a
        href="{{ section.settings.cta_link | default: '#' }}"
        class="custom-header__cta-button"
        aria-label="{{ section.settings.cta_label | default: 'CHOOSE GIFT' }}"
      >
        <span class="cta-text">{{ section.settings.cta_label | default: 'CHOOSE GIFT' }}</span>
        <svg
          class="cta-arrow"
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </a>
    </div>

  </div>{% comment %} end .custom-header__container {% endcomment %}

  {% comment %} MOBILE MENU DRAWER (hidden by default, toggled by JS) {% endcomment %}
  <div class="custom-header__mobile-menu" id="mobile-menu" aria-hidden="true">
    <div class="custom-header__mobile-menu-inner">

      {% comment %} Tagline {% endcomment %}
      <p class="custom-header__mobile-tagline">
        {{ section.settings.tagline | default: 'Find the ideal gift for your loved ones.' }}
      </p>

      {% comment %} Mobile CTA button {% endcomment %}
      <a
        href="{{ section.settings.cta_link | default: '#' }}"
        class="custom-header__mobile-cta"
        aria-label="{{ section.settings.cta_label | default: 'CHOOSE GIFT' }}"
      >
        <span class="cta-text">{{ section.settings.cta_label | default: 'CHOOSE GIFT' }}</span>
        <svg
          class="cta-arrow"
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </a>

    </div>{% comment %} end .custom-header__mobile-menu-inner {% endcomment %}
  </div>{% comment %} end .custom-header__mobile-menu {% endcomment %}

</div>{% comment %} end .custom-header {% endcomment %}

<script src="{{ 'site-header.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline Text",
      "default": "Find the ideal gift for your loved ones."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA Button Label",
      "default": "CHOOSE GIFT"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA Button Link",
      "default": "/"
    }
  ],
  "presets": [
    {
      "name": "Header",
      "category": "Custom"
    }
  ]
}
{% endschema %}
