{% comment %}
  hero.liquid – Custom Line-Art Hero Section
  ──────────────────────────────────────────
  Layout
  ──────
  ZONE 1  Full-width top banner image (1440 x 390 px).
          On mobile the banner moves below the text and a button
          is overlaid on top of it.
  ZONE 2  Two-column content row:
            LEFT   Heading + subtext + desktop CTA button
            RIGHT  Side illustration image
  ──────────────────────────────────────────
  Assets loaded by this section
  ──────────────────────────────
  assets/hero.css  - section-scoped styles
  assets/hero.js   - ripple + scroll-animation enhancements
{% endcomment %}

{{ 'hero.css' | asset_url | stylesheet_tag }}

<div
  class="custom-hero-section section-{{ section.id }}"
  data-section-id="{{ section.id }}"
  data-section-type="hero"
>

  {% comment %} ZONE 1 - TOP BANNER IMAGE
    Displays the full-width line-art banner.
    Falls back to the built-in hero.svg when no image is set.
  {% endcomment %}
  <div class="hero-top-banner-wrapper">
    {% if section.settings.background_image != blank %}
      <img
        src="{{ section.settings.background_image | image_url: width: 1440 }}"
        alt="Hero Line Art Banner"
        width="1440"
        height="390"
        loading="eager"
        class="hero-banner-img"
      >
    {% else %}
      <img
        src="{{ 'hero.svg' | asset_url }}"
        alt="Hero Line Art Banner"
        width="1440"
        height="390"
        loading="eager"
        class="hero-banner-img"
      >
    {% endif %}

    {% comment %} Button overlaid on the banner image - visible on mobile only {% endcomment %}
    <div class="hero-mobile-button-wrapper">
      <a
        href="{{ section.settings.button_link | default: '#' }}"
        class="custom-hero-button custom-hero-button--mobile"
        aria-label="{{ section.settings.button_label | default: 'SHOP NOW' }}"
      >
        <span class="button-text">{{ section.settings.button_label | default: 'SHOP NOW' }}</span>
        <svg class="arrow-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24"
             viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
             aria-hidden="true">
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </a>
    </div>
  </div>{% comment %} end .hero-top-banner-wrapper {% endcomment %}


  {% comment %} ZONE 2 - SPLIT CONTENT AREA (Side-by-Side)
    Left  : heading, subtext, desktop CTA button
    Right : side illustration (hidden on mobile)
  {% endcomment %}
  <div class="hero-bottom-container">
    <div class="hero-content-row">

      {% comment %} LEFT COLUMN {% endcomment %}
      <div class="hero-content-column-left">

        {% if section.settings.title != blank %}
          <h1 class="custom-hero-heading">{{ section.settings.title }}</h1>
        {% endif %}

        <div class="custom-hero-body-wrapper">
          {% if section.settings.subtext != blank %}
            <p class="custom-hero-subtext">{{ section.settings.subtext }}</p>
          {% endif %}
        </div>

        {% comment %} Desktop CTA button - hidden on mobile {% endcomment %}
        <a
          href="{{ section.settings.button_link | default: '#' }}"
          class="custom-hero-button custom-hero-button--desktop"
          aria-label="{{ section.settings.button_label | default: 'SHOP NOW' }}"
        >
          <span class="button-text">{{ section.settings.button_label | default: 'SHOP NOW' }}</span>
          <svg class="arrow-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24"
               viewBox="0 0 24 24" fill="none" stroke="currentColor"
               stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
               aria-hidden="true">
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        </a>

      </div>{% comment %} end .hero-content-column-left {% endcomment %}

      {% comment %} RIGHT COLUMN - Illustration {% endcomment %}
      <div class="hero-content-column-right">
        {% if section.settings.background_image != blank %}
          <img
            src="{{ section.settings.background_image | image_url: width: 900 }}"
            alt="Hero Side Graphic"
            width="890"
            height="402"
            loading="lazy"
            class="hero-side-illustration"
          >
        {% else %}
          <img
            src="{{ 'hero.svg' | asset_url }}"
            alt="Hero Side Graphic"
            width="890"
            height="402"
            loading="lazy"
            class="hero-side-illustration"
          >
        {% endif %}
      </div>{% comment %} end .hero-content-column-right {% endcomment %}

    </div>{% comment %} end .hero-content-row {% endcomment %}
  </div>{% comment %} end .hero-bottom-container {% endcomment %}

</div>{% comment %} end .custom-hero-section {% endcomment %}

<script src="{{ 'hero.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Line Art Image Asset"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "The Gift Guide"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "Discover Joy: Your Ultimate Holiday Gift Destination. Explore our curated selection and find the perfect gifts to delight your loved ones this holiday season."
    },
    {
      "type": "image_picker",
      "id": "avatar_image",
      "label": "Custom Avatar Image"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "SHOP NOW"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "Hero",
      "category": "Custom"
    }
  ]
}
{% endschema %}
