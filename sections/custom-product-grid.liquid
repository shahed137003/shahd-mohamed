{{ 'custom-product-grid.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign product_handles = ''
  if section.settings.product_list != blank
    if section.settings.product_list.first != blank
      assign product_handles = section.settings.product_list | map: 'handle' | join: ','
    else
      assign product_handles = section.settings.product_list
    endif
  endif
-%}

<div class="custom-product-grid section-{{ section.id }}" 
     data-section-id="{{ section.id }}" 
     data-section-type="product-grid"
     data-product-handles="{{ product_handles }}">
  
  <div class="custom-product-grid__container">
    
    <!-- Section Header -->
    <div class="custom-product-grid__header">
      <h2 class="custom-product-grid__title">{{ section.settings.title | default: 'Tisso vison in the wild' }}</h2>
      {% if section.settings.description != blank %}
        <p class="custom-product-grid__description">{{ section.settings.description }}</p>
      {% endif %}
    </div>

    <!-- Product Grid -->
    <div class="custom-product-grid__grid" id="product-grid-{{ section.id }}">
      <!-- Products will be rendered by JavaScript -->
    </div>
    
    <!-- Loading State -->
    <div class="custom-product-grid__loading" id="loading-{{ section.id }}">
      <div class="spinner"></div>
      <p>Loading products...</p>
    </div>
    
  </div>
</div>

{% schema %}
{
  "name": "Custom Product Grid",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "Tisso vison in the wild"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Section Description",
      "default": "Explore our curated collection"
    },
    {
      "type": "product_list",
      "id": "product_list",
      "label": "Product List",
      "limit": 6
    }
  ],
  "presets": [
    {
      "name": "Custom Product Grid",
      "category": "Custom"
    }
  ]
}
{% endschema %}

<script src="{{ 'custom-product-grid.js' | asset_url }}" defer></script>